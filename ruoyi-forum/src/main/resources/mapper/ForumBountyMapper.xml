<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.forum.mapper.ForumBountyMapper">

    <resultMap type="ForumBounty" id="ForumBountyResult">
        <result property="bountyId"    column="bounty_id"    />
        <result property="postId"    column="post_id"    />
        <result property="userId"    column="user_id"    />
        <result property="coins"    column="coins"    />
        <result property="status"    column="status"    />
        <result property="acceptedAnswerId"    column="accepted_answer_id"    />
        <result property="expireTime"    column="expire_time"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectForumBountyVo">
        select bounty_id, post_id, user_id, coins, status, accepted_answer_id, expire_time, create_time, update_time from forum_bounty
    </sql>

    <select id="selectForumBountyList" parameterType="ForumBounty" resultMap="ForumBountyResult">
        <include refid="selectForumBountyVo"/>
        <where>
            <if test="postId != null "> and post_id = #{postId}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="coins != null "> and coins = #{coins}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="acceptedAnswerId != null "> and accepted_answer_id = #{acceptedAnswerId}</if>
            <if test="expireTime != null "> and expire_time = #{expireTime}</if>
        </where>
    </select>

    <select id="selectForumBountyByBountyId" parameterType="Long" resultMap="ForumBountyResult">
        <include refid="selectForumBountyVo"/>
        where bounty_id = #{bountyId}
    </select>

    <insert id="insertForumBounty" parameterType="ForumBounty" useGeneratedKeys="true" keyProperty="bountyId">
        insert into forum_bounty
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="postId != null">post_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="coins != null">coins,</if>
            <if test="status != null">status,</if>
            <if test="acceptedAnswerId != null">accepted_answer_id,</if>
            <if test="expireTime != null">expire_time,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="postId != null">#{postId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="coins != null">#{coins},</if>
            <if test="status != null">#{status},</if>
            <if test="acceptedAnswerId != null">#{acceptedAnswerId},</if>
            <if test="expireTime != null">#{expireTime},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateForumBounty" parameterType="ForumBounty">
        update forum_bounty
        <trim prefix="SET" suffixOverrides=",">
            <if test="postId != null">post_id = #{postId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="coins != null">coins = #{coins},</if>
            <if test="status != null">status = #{status},</if>
            <if test="acceptedAnswerId != null">accepted_answer_id = #{acceptedAnswerId},</if>
            <if test="expireTime != null">expire_time = #{expireTime},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where bounty_id = #{bountyId}
    </update>

    <delete id="deleteForumBountyByBountyId" parameterType="Long">
        delete from forum_bounty where bounty_id = #{bountyId}
    </delete>

    <delete id="deleteForumBountyByBountyIds" parameterType="String">
        delete from forum_bounty where bounty_id in
        <foreach item="bountyId" collection="array" open="(" separator="," close=")">
            #{bountyId}
        </foreach>
    </delete>
</mapper>