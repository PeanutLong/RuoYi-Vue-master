<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.forum.mapper.ForumAnswerMapper">

    <resultMap type="ForumAnswer" id="ForumAnswerResult">
        <result property="answerId"    column="answer_id"    />
        <result property="postId"    column="post_id"    />
        <result property="userId"    column="user_id"    />
        <result property="content"    column="content"    />
        <result property="isAccepted"    column="is_accepted"    />
        <result property="likeCount"    column="like_count"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectForumAnswerVo">
        select answer_id, post_id, user_id, content, is_accepted, like_count, create_time, update_time from forum_answer
    </sql>

    <select id="selectForumAnswerList" parameterType="ForumAnswer" resultMap="ForumAnswerResult">
        <include refid="selectForumAnswerVo"/>
        <where>
            <if test="postId != null "> and post_id = #{postId}</if>
            <if test="userId != null "> and user_id = #{userId}</if>
            <if test="content != null  and content != ''"> and content = #{content}</if>
            <if test="isAccepted != null  and isAccepted != ''"> and is_accepted = #{isAccepted}</if>
            <if test="likeCount != null "> and like_count = #{likeCount}</if>
        </where>
    </select>

    <select id="selectForumAnswerByAnswerId" parameterType="Long" resultMap="ForumAnswerResult">
        <include refid="selectForumAnswerVo"/>
        where answer_id = #{answerId}
    </select>

    <insert id="insertForumAnswer" parameterType="ForumAnswer" useGeneratedKeys="true" keyProperty="answerId">
        insert into forum_answer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="postId != null">post_id,</if>
            <if test="userId != null">user_id,</if>
            <if test="content != null and content != ''">content,</if>
            <if test="isAccepted != null">is_accepted,</if>
            <if test="likeCount != null">like_count,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="postId != null">#{postId},</if>
            <if test="userId != null">#{userId},</if>
            <if test="content != null and content != ''">#{content},</if>
            <if test="isAccepted != null">#{isAccepted},</if>
            <if test="likeCount != null">#{likeCount},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateForumAnswer" parameterType="ForumAnswer">
        update forum_answer
        <trim prefix="SET" suffixOverrides=",">
            <if test="postId != null">post_id = #{postId},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="content != null and content != ''">content = #{content},</if>
            <if test="isAccepted != null">is_accepted = #{isAccepted},</if>
            <if test="likeCount != null">like_count = #{likeCount},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where answer_id = #{answerId}
    </update>

    <delete id="deleteForumAnswerByAnswerId" parameterType="Long">
        delete from forum_answer where answer_id = #{answerId}
    </delete>

    <delete id="deleteForumAnswerByAnswerIds" parameterType="String">
        delete from forum_answer where answer_id in
        <foreach item="answerId" collection="array" open="(" separator="," close=")">
            #{answerId}
        </foreach>
    </delete>
</mapper>